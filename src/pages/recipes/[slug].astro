---
/**
 * Recipe Detail Page (/recipes/[slug])
 *
 * Renders a full recipe with:
 * - Hero image with metadata bar
 * - Print button (links to /recipes/print/[slug] for clean print view)
 * - Checkable ingredient list (React island)
 * - Step-by-step instructions with optional images
 * - Tips section (Portable Text)
 * - Video embed (if videoUrl present)
 * - Share buttons (Pinterest, Facebook, X)
 * - Related recipes (same category)
 * - schema.org/Recipe JSON-LD structured data
 * - Per-page Open Graph, Twitter Card, and Pinterest meta
 */
import RecipeLayout from '@layouts/RecipeLayout.astro';
import Badge from '@components/shared/Badge.astro';
import PortableText from '@components/shared/PortableText.astro';
import VideoEmbed from '@components/video/VideoEmbed.astro';
import RecipeCard from '@components/recipe/RecipeCard.astro';
import ShareButtons from '@components/shared/ShareButtons.astro';
import IngredientChecklist from '@components/recipe/IngredientChecklist.tsx';
import JumpToRecipe from '@components/recipe/JumpToRecipe.tsx';
import { sanityFetch, recipeQueries, sanityClient } from '@lib/sanity';
import { imageUrl, imageSrcSet, placeholderColor } from '@lib/image';
import {
  formatTime,
  formatTotalTime,
  capitalize,
  buildRecipeSchema,
} from '@lib/recipeHelpers';

// --- STATIC PATHS ---
export async function getStaticPaths() {
  const recipes = await sanityClient.fetch(`
    *[_type == "recipe"] { slug }
  `);
  return (recipes || [])
    .filter((r: any) => r.slug?.current)
    .map((r: any) => ({
      params: { slug: r.slug.current },
    }));
}

// --- FETCH RECIPE DATA ---
const { slug } = Astro.params;

const recipe = await sanityFetch<any>(recipeQueries.bySlug, { slug });

if (!recipe) {
  return Astro.redirect('/recipes');
}

// Fetch site name for schema.org author
const siteSettings = await sanityClient.fetch(
  `*[_type == "siteSettings"][0] { siteName }`
);
const siteName = siteSettings?.siteName || undefined;

// --- RELATED RECIPES ---
const categoryIds = (recipe.categories || []).map((c: any) => c._id);
let relatedRecipes: any[] = [];

if (categoryIds.length > 0) {
  relatedRecipes = await sanityClient.fetch(
    `*[_type == "recipe" && _id != $id && count((categories[]->_id)[@ in $cats]) > 0] | order(publishedAt desc) [0...4] {
      _id,
      title,
      slug,
      mainImage,
      prepTime,
      cookTime,
      difficulty,
      categories[]->{ _id, title, slug }
    }`,
    { id: recipe._id, cats: categoryIds }
  );
}

// --- COMPUTED VALUES ---
const totalTime = (recipe.prepTime || 0) + (recipe.cookTime || 0);
const totalTimeLabel = formatTotalTime(recipe.prepTime, recipe.cookTime);
const prepTimeLabel = formatTime(recipe.prepTime);
const cookTimeLabel = formatTime(recipe.cookTime);
const difficultyLabel = capitalize(recipe.difficulty);
const hasImage = !!recipe.mainImage?.asset;
const bgColor = placeholderColor(recipe.mainImage);
const heroSrc = hasImage ? imageUrl(recipe.mainImage, 1200) : '';
const heroSrcSet = hasImage
  ? imageSrcSet(recipe.mainImage, [600, 900, 1200, 1600])
  : '';

// OG image (1200x630 landscape for Facebook/Twitter)
const ogImageUrl = hasImage ? imageUrl(recipe.mainImage, 1200) : undefined;

// Pinterest image (2:3 portrait ratio for optimal pin display)
const pinterestImageUrl = hasImage
  ? imageUrl(recipe.mainImage, 1000)
  : undefined;

// Full canonical URL for share buttons
const siteUrl = Astro.site?.origin || 'https://example.com';
const pageUrl = `${siteUrl}/recipes/${recipe.slug.current}`;

// Print view URL
const printUrl = `/recipes/print/${recipe.slug.current}`;

// schema.org JSON-LD
const recipeSchema = buildRecipeSchema(recipe, siteUrl, ogImageUrl, siteName);
---

<RecipeLayout
  title={recipe.title}
  description={recipe.description}
  ogImage={ogImageUrl}
  pinterestImage={pinterestImageUrl}
  publishedDate={recipe.publishedAt}
>
  {/* schema.org/Recipe structured data */}
  <script
    type="application/ld+json"
    set:html={JSON.stringify(recipeSchema)}
  />

  <article class="recipe-detail">
    {/* Jump to Recipe floating button */}
    <JumpToRecipe client:load />
    {/* --- Hero Image --- */}
    <div class="max-w-content mx-auto px-10 pt-12 max-md:px-5 max-md:pt-8">
      <div class="relative overflow-hidden">
        {hasImage ? (
          <img
            src={heroSrc}
            srcset={heroSrcSet}
            sizes="(max-width: 768px) 100vw, (max-width: 1200px) 90vw, 1120px"
            alt={recipe.mainImage?.alt || recipe.title}
            class="w-full aspect-16/10 object-cover block"
            width="1120"
            height="700"
          />
        ) : (
          <div
            class="aspect-16/10 flex items-center justify-center"
            style={`background: linear-gradient(145deg, ${bgColor}, ${bgColor}CC);`}
          >
            <span class="text-black/10 text-sm font-semibold tracking-wider uppercase font-sans">photo</span>
          </div>
        )}
        {/* Category badges */}
        {recipe.categories?.length > 0 && (
          <div class="absolute top-4 left-4 flex gap-2">
            {recipe.categories.map((cat: any) => (
              <a href={`/recipes?category=${cat.slug.current}`}>
                <Badge label={cat.title} variant="overlay" />
              </a>
            ))}
          </div>
        )}
      </div>
    </div>

    {/* --- Recipe Header --- */}
    <div class="max-w-narrow mx-auto px-10 max-md:px-5">
      <header class="pt-10 pb-8 border-b border-border max-md:pt-6 max-md:pb-6">
        {/* Dietary badges */}
        {recipe.dietary?.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-4">
            {recipe.dietary.map((d: string) => (
              <span class="font-sans text-[10px] font-bold tracking-widest uppercase text-green-deep bg-green-bright/10 px-2.5 py-1">
                {d}
              </span>
            ))}
          </div>
        )}

        <h1 class="font-serif text-[42px] font-normal text-text-primary leading-[1.15] tracking-tight m-0 max-md:text-[32px]">
          {recipe.title}
        </h1>

        {recipe.description && (
          <p class="font-sans text-[15px] text-text-md leading-[1.75] mt-4 mb-0">
            {recipe.description}
          </p>
        )}

        {/* Metadata bar */}
        <div class="flex flex-wrap gap-x-8 gap-y-3 mt-6 max-md:mt-4">
          {prepTimeLabel && (
            <div class="recipe-meta-item">
              <span class="recipe-meta-label">Prep</span>
              <span class="recipe-meta-value">{prepTimeLabel}</span>
            </div>
          )}
          {cookTimeLabel && (
            <div class="recipe-meta-item">
              <span class="recipe-meta-label">Cook</span>
              <span class="recipe-meta-value">{cookTimeLabel}</span>
            </div>
          )}
          {totalTime > 0 && (
            <div class="recipe-meta-item">
              <span class="recipe-meta-label">Total</span>
              <span class="recipe-meta-value">{totalTimeLabel}</span>
            </div>
          )}
          {recipe.servings && (
            <div class="recipe-meta-item">
              <span class="recipe-meta-label">Servings</span>
              <span class="recipe-meta-value">{recipe.servings}</span>
            </div>
          )}
          {difficultyLabel && (
            <div class="recipe-meta-item">
              <span class="recipe-meta-label">Difficulty</span>
              <span class="recipe-meta-value">{difficultyLabel}</span>
            </div>
          )}
        </div>
      </header>

      {/* --- Action bar: Jump links + Share + Print --- */}
      <div class="flex flex-wrap items-center justify-between gap-4 py-4 border-b border-border" id="recipe-content">
        <div class="flex gap-4">
          <a href="#ingredients" class="recipe-jump-link">Ingredients</a>
          <span class="text-border">|</span>
          <a href="#instructions" class="recipe-jump-link">Instructions</a>
          {recipe.tips?.length > 0 && (
            <>
              <span class="text-border">|</span>
              <a href="#tips" class="recipe-jump-link">Tips</a>
            </>
          )}
          {recipe.videoUrl && (
            <>
              <span class="text-border">|</span>
              <a href="#video" class="recipe-jump-link">Video</a>
            </>
          )}
        </div>
        <div class="flex items-center gap-4">
          <ShareButtons
            url={pageUrl}
            title={recipe.title}
            description={recipe.description || ''}
            imageUrl={ogImageUrl}
          />
          <a
            href={printUrl}
            target="_blank"
            rel="noopener"
            class="print-button"
            aria-label="Print this recipe"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="6 9 6 2 18 2 18 9" />
              <path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2" />
              <rect x="6" y="14" width="12" height="8" />
            </svg>
            <span>Print</span>
          </a>
        </div>
      </div>

      {/* --- Ingredients --- */}
      <section id="ingredients" class="py-10 border-b border-border max-md:py-6">
        <h2 class="font-serif text-[28px] font-medium text-text-primary mb-6 m-0">Ingredients</h2>
        <IngredientChecklist
          client:load
          ingredients={recipe.ingredients || []}
        />
      </section>

      {/* --- Instructions --- */}
      <section id="instructions" class="py-10 border-b border-border max-md:py-6">
        <h2 class="font-serif text-[28px] font-medium text-text-primary mb-8 m-0">Instructions</h2>

        <ol class="recipe-steps">
          {(recipe.instructions || []).map((step: any, i: number) => (
            <li class="recipe-step">
              <div class="recipe-step-number">
                <span>{String(i + 1).padStart(2, '0')}</span>
              </div>
              <div class="recipe-step-content">
                <p class="font-sans text-[15px] leading-[1.75] text-text-md m-0">
                  {step.stepText}
                </p>
                {step.tip && (
                  <div class="recipe-step-tip">
                    <span class="font-sans text-[11px] font-bold tracking-wider uppercase text-copper">Tip:</span>
                    <span class="font-sans text-[13px] text-text-md ml-2">{step.tip}</span>
                  </div>
                )}
                {step.image?.asset && (
                  <img
                    src={imageUrl(step.image, 600)}
                    srcset={imageSrcSet(step.image, [300, 600])}
                    sizes="(max-width: 768px) 100vw, 600px"
                    alt={step.image?.alt || `Step ${i + 1}`}
                    loading="lazy"
                    width="600"
                    height="450"
                    class="mt-4 w-full max-w-[600px] aspect-4/3 object-cover"
                  />
                )}
              </div>
            </li>
          ))}
        </ol>
      </section>

      {/* --- Tips & Variations --- */}
      {recipe.tips?.length > 0 && (
        <section id="tips" class="py-10 border-b border-border max-md:py-6">
          <h2 class="font-serif text-[28px] font-medium text-text-primary mb-6 m-0">Tips and Variations</h2>
          <PortableText content={recipe.tips} />
        </section>
      )}

      {/* --- Video --- */}
      {recipe.videoUrl && (
        <section id="video" class="py-10 border-b border-border max-md:py-6">
          <h2 class="font-serif text-[28px] font-medium text-text-primary mb-6 m-0">Watch the Recipe</h2>
          <VideoEmbed url={recipe.videoUrl} title={recipe.title} />
        </section>
      )}

      {/* --- Tags --- */}
      {(recipe.tags?.length > 0 || recipe.occasion?.length > 0 || recipe.season) && (
        <div class="py-6 flex flex-wrap gap-2">
          {recipe.season && (
            <a href={`/recipes?season=${recipe.season}`} class="recipe-tag">
              {capitalize(recipe.season)}
            </a>
          )}
          {(recipe.occasion || []).map((o: string) => (
            <a href={`/recipes?occasion=${o}`} class="recipe-tag">
              {capitalize(o.replace(/-/g, ' '))}
            </a>
          ))}
          {(recipe.tags || []).map((tag: string) => (
            <span class="recipe-tag">{tag}</span>
          ))}
        </div>
      )}
    </div>

    {/* --- Related Recipes --- */}
    {relatedRecipes.length > 0 && (
      <section class="max-w-content mx-auto px-10 py-16 max-md:px-5 max-md:py-10">
        <h2 class="font-serif text-[28px] font-normal text-text-primary mb-8 m-0 pb-4 border-b border-border">
          You Might Also Like
        </h2>
        <div class="grid grid-cols-4 gap-6 max-lg:grid-cols-3 max-md:grid-cols-2 max-sm:grid-cols-1">
          {relatedRecipes.map((related: any) => (
            <RecipeCard recipe={related} />
          ))}
        </div>
      </section>
    )}
  </article>
</RecipeLayout>

<style>
  /* Metadata items */
  .recipe-meta-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .recipe-meta-label {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-light);
  }
  .recipe-meta-value {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
  }

  /* Jump links */
  .recipe-jump-link {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-md);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .recipe-jump-link:hover {
    color: var(--green-deep);
  }

  /* Print button (now an <a> link to the print page) */
  .print-button {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-md);
    background: none;
    border: 1px solid var(--border);
    padding: 7px 14px;
    cursor: pointer;
    text-decoration: none;
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }
  .print-button:hover {
    color: var(--green-deep);
    border-color: var(--green-deep);
    background: var(--cream);
  }

  /* Instruction steps */
  .recipe-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: step;
  }
  .recipe-step {
    display: flex;
    gap: 24px;
    padding: 24px 0;
    border-bottom: 1px solid var(--border);
  }
  .recipe-step:last-child {
    border-bottom: none;
  }
  .recipe-step-number {
    flex-shrink: 0;
    width: 48px;
    text-align: center;
  }
  .recipe-step-number span {
    font-family: var(--font-serif);
    font-size: 32px;
    font-weight: 300;
    color: var(--copper);
    opacity: 0.5;
  }
  .recipe-step-content {
    flex: 1;
    min-width: 0;
  }
  .recipe-step-tip {
    margin-top: 12px;
    padding: 12px 16px;
    background: var(--cream);
    border-left: 3px solid var(--copper);
  }

  /* Tags */
  .recipe-tag {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    color: var(--text-md);
    background: var(--cream);
    padding: 6px 14px;
    text-decoration: none;
    transition: background 0.2s ease;
  }
  .recipe-tag:hover {
    background: var(--border);
  }

  @media (max-width: 640px) {
    .recipe-step {
      flex-direction: column;
      gap: 8px;
    }
    .recipe-step-number {
      width: auto;
      text-align: left;
    }
    .recipe-step-number span {
      font-size: 24px;
    }
  }
</style>
