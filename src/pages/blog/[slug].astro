---
/**
 * Blog Detail Page (/blog/[slug])
 *
 * Renders a blog post with:
 * - Featured image
 * - Portable Text rich content body
 * - Video embed (if videoUrl present)
 * - Share buttons (Pinterest, Facebook, X)
 * - Category tags
 * - Per-page OG/Twitter meta with og:type article
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import PortableText from '@components/shared/PortableText.astro';
import VideoEmbed from '@components/video/VideoEmbed.astro';
import ShareButtons from '@components/shared/ShareButtons.astro';
import { sanityFetch, blogQueries, sanityClient } from '@lib/sanity';
import { imageUrl, imageSrcSet, placeholderColor } from '@lib/image';

// --- STATIC PATHS ---
export async function getStaticPaths() {
  const posts = await sanityClient.fetch(`
    *[_type == "blogPost"] { slug }
  `);
  return (posts || [])
    .filter((p: any) => p.slug?.current)
    .map((p: any) => ({
      params: { slug: p.slug.current },
    }));
}

// --- FETCH DATA ---
const { slug } = Astro.params;
const post = await sanityFetch<any>(blogQueries.bySlug, { slug });

if (!post) {
  return Astro.redirect('/blog');
}

const hasImage = !!post.mainImage?.asset;
const bgColor = placeholderColor(post.mainImage);
const heroSrc = hasImage ? imageUrl(post.mainImage, 1200) : '';
const heroSrcSet = hasImage ? imageSrcSet(post.mainImage, [600, 900, 1200, 1600]) : '';
const ogImageUrl = hasImage ? imageUrl(post.mainImage, 1200) : undefined;

const siteUrl = Astro.site?.origin || 'https://example.com';
const pageUrl = `${siteUrl}/blog/${post.slug.current}`;

const dateLabel = post.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : '';
---

<BaseLayout
  title={post.title}
  description={post.description}
  ogImage={ogImageUrl}
  ogType="article"
  publishedDate={post.publishedAt}
>
  <article class="blog-detail">
    {/* --- Hero Image --- */}
    {(hasImage || bgColor) && (
      <div class="max-w-content mx-auto px-10 pt-12 max-md:px-5 max-md:pt-8">
        <div class="overflow-hidden">
          {hasImage ? (
            <img
              src={heroSrc}
              srcset={heroSrcSet}
              sizes="(max-width: 768px) 100vw, (max-width: 1200px) 90vw, 1120px"
              alt={post.mainImage?.alt || post.title}
              class="w-full aspect-16/10 object-cover block"
              width="1120"
              height="700"
              loading="eager"
            />
          ) : (
            <div
              class="aspect-16/10 flex items-center justify-center"
              style={`background: linear-gradient(145deg, ${bgColor}, ${bgColor}CC);`}
            >
              <span class="text-black/10 text-sm font-semibold tracking-wider uppercase font-sans">photo</span>
            </div>
          )}
        </div>
      </div>
    )}

    {/* --- Post Header --- */}
    <div class="max-w-narrow mx-auto px-10 max-md:px-5">
      <header class="pt-10 pb-8 border-b border-border max-md:pt-6 max-md:pb-6">
        {dateLabel && (
          <time datetime={post.publishedAt} class="font-sans text-xs text-text-light mb-3 block">
            {dateLabel}
          </time>
        )}
        <h1 class="font-serif text-[42px] font-normal text-text-primary leading-[1.15] tracking-tight m-0 max-md:text-[32px]">
          {post.title}
        </h1>
        {post.description && (
          <p class="font-sans text-[15px] text-text-md leading-[1.75] mt-4 mb-0">
            {post.description}
          </p>
        )}
      </header>

      {/* --- Share buttons --- */}
      <div class="py-4 border-b border-border">
        <ShareButtons
          url={pageUrl}
          title={post.title}
          description={post.description || ''}
          imageUrl={ogImageUrl}
        />
      </div>

      {/* --- Body Content --- */}
      {post.body?.length > 0 && (
        <div class="py-10 border-b border-border max-md:py-6">
          <PortableText content={post.body} />
        </div>
      )}

      {/* --- Video --- */}
      {post.videoUrl && (
        <div class="py-10 border-b border-border max-md:py-6">
          <h2 class="font-serif text-[28px] font-medium text-text-primary mb-6 m-0">Watch</h2>
          <VideoEmbed url={post.videoUrl} title={post.title} />
        </div>
      )}

      {/* --- Categories --- */}
      {post.categories?.length > 0 && (
        <div class="py-6">
          <div class="flex flex-wrap gap-2">
            {post.categories.map((cat: any) => (
              <span class="font-sans text-xs font-medium text-text-md bg-cream px-3.5 py-1.5">
                {cat.title}
              </span>
            ))}
          </div>
        </div>
      )}
    </div>
  </article>
</BaseLayout>
