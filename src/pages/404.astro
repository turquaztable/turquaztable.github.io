---
/**
 * 404 - Page Not Found
 *
 * Astro automatically uses this file for 404 responses.
 * Matches the editorial design system with helpful navigation.
 */
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found" showUtilityBar={false}>
  <section class="section-container py-24 text-center max-md:py-16">
    <p class="font-sans text-[11px] font-bold tracking-[0.25em] uppercase text-copper mb-4">
      Page Not Found
    </p>
    <h1 class="font-serif text-[64px] font-light text-text-primary leading-none mb-6 max-md:text-[48px]">
      404
    </h1>
    <p class="font-sans text-[15px] text-text-md leading-relaxed max-w-[440px] mx-auto mb-10">
      The page you are looking for might have been moved, renamed, or
      does not exist. Try searching for what you need or head back to
      the homepage.
    </p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a
        href="/"
        class="inline-flex items-center gap-2 font-sans text-xs font-bold tracking-wider uppercase text-green-deep border-2 border-green-deep px-8 py-3.5 hover:bg-green-deep hover:text-white transition-colors"
      >
        Back to Home
      </a>
      <a
        href="/recipes"
        class="inline-flex items-center gap-2 font-sans text-xs font-bold tracking-wider uppercase text-copper border-2 border-copper px-8 py-3.5 hover:bg-copper hover:text-white transition-colors"
      >
        Browse Recipes
      </a>
    </div>
  </section>
</BaseLayout>
