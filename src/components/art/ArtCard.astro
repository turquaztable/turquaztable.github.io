---
/**
 * ArtCard.astro - Art/painting card for gallery listing pages.
 * Square (1:1) image with title and medium overlay.
 *
 * Usage:
 *   <ArtCard post={artPost} />
 *   <ArtCard post={artPost} eager />
 */
import { imageUrl, imageSrcSet, placeholderColor } from '@lib/image';

interface ArtPostData {
  _id: string;
  title: string;
  slug: { current: string };
  description?: string;
  gallery?: any[];
  medium?: string;
  forSale?: boolean;
  publishedAt?: string;
}

interface Props {
  post: ArtPostData;
  eager?: boolean;
}

const { post, eager = false } = Astro.props;

const firstImage = post.gallery?.[0];
const hasImage = !!firstImage?.asset;
const bgColor = placeholderColor(firstImage);
const imgSrc = hasImage ? imageUrl(firstImage, 600) : '';
const imgSrcSetStr = hasImage ? imageSrcSet(firstImage, [300, 600, 900]) : '';
---

<a
  href={`/art/${post.slug.current}`}
  class="art-card group block"
>
  {/* Image */}
  <div class="overflow-hidden relative">
    <div class="transition-transform duration-500 ease-[cubic-bezier(0.2,0,0,1)] group-hover:scale-[1.03]">
      {hasImage ? (
        <img
          src={imgSrc}
          srcset={imgSrcSetStr}
          sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
          alt={firstImage?.alt || post.title}
          loading={eager ? 'eager' : 'lazy'}
          width="600"
          height="600"
          class="w-full aspect-square object-cover block"
        />
      ) : (
        <div
          class="aspect-square flex items-center justify-center"
          style={`background: linear-gradient(145deg, ${bgColor}, ${bgColor}CC);`}
        >
          <span class="text-black/10 text-[11px] font-semibold tracking-wider uppercase font-sans">photo</span>
        </div>
      )}
    </div>
    {/* For sale indicator */}
    {post.forSale && (
      <span class="absolute top-3 right-3 px-2.5 py-1 bg-copper text-white text-[10px] font-bold tracking-widest uppercase font-sans z-[2]">
        Available
      </span>
    )}
  </div>

  {/* Text */}
  <div class="pt-3.5">
    <h3 class="font-serif text-base font-semibold text-text-primary leading-[1.3] line-clamp-2 m-0">
      {post.title}
    </h3>
    {post.medium && (
      <p class="mt-1.5 text-xs text-text-light font-sans font-medium m-0">
        {post.medium}
      </p>
    )}
  </div>
</a>

<style>
  .art-card {
    transition: transform 0.35s cubic-bezier(0.2, 0, 0, 1), box-shadow 0.35s ease;
  }
  .art-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.08);
  }
</style>
