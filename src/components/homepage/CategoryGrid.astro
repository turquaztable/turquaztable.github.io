---
/**
 * CategoryGrid.astro
 * 5-column photo grid with white label badges overlaid on category images.
 * Pattern reference: Gimme Some Oven category layout.
 * Data: recipe categories from Sanity with images.
 */
import { imageUrl, imageSrcSet, placeholderColor } from '@lib/image';

interface Category {
  _id: string;
  title: string;
  slug: { current: string };
  image?: any;
  description?: string;
}

interface Props {
  categories: Category[];
}

const { categories } = Astro.props;

// Limit to 5 categories for the homepage grid
const displayCategories = categories.slice(0, 5);
---

<section class="border-b border-border bg-surface">
  <div class="max-w-content mx-auto px-10 py-10 pb-11 max-md:px-5 max-md:py-8">
    <h2 class="font-sans text-xs font-bold tracking-[4px] uppercase text-center text-text-md mb-7 flex items-center gap-5 justify-center">
      <span class="w-[60px] h-px bg-border block"></span>
      BROWSE BY CATEGORY
      <span class="w-[60px] h-px bg-border block"></span>
    </h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
      {displayCategories.map((cat) => {
        const bgColor = placeholderColor(cat.image);
        const hasImage = !!cat.image?.asset;
        return (
          <a
            href={`/recipes?category=${cat.slug.current}`}
            class="category-card relative overflow-hidden aspect-4/3 block group"
            style={`background: linear-gradient(145deg, ${bgColor}, ${bgColor}CC);`}
          >
            {hasImage && (
              <img
                src={imageUrl(cat.image, 400)}
                srcset={imageSrcSet(cat.image, [300, 400, 600])}
                sizes="(max-width: 640px) 50vw, 20vw"
                alt={cat.title}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 ease-[cubic-bezier(0.2,0,0,1)] group-hover:scale-105"
                loading="lazy"
              />
            )}
            <div class="absolute inset-0 bg-black/[0.15] group-hover:bg-black/[0.08] transition-colors duration-300 z-[1]" />
            <div class="absolute inset-0 flex items-center justify-center z-[2]">
              <span class="font-sans text-[12px] font-bold tracking-[2.5px] uppercase text-text-primary bg-white/[0.88] backdrop-blur-sm px-[18px] py-2 group-hover:bg-white/95 transition-colors duration-200">
                {cat.title}
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>
