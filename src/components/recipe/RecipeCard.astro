---
/**
 * RecipeCard.astro - Standalone recipe card for listing pages.
 * Extracts the pattern from LatestToggle's inline RecipeCard
 * but as a full Astro component with Tailwind + responsive images.
 *
 * Usage:
 *   <RecipeCard recipe={recipe} />
 *   <RecipeCard recipe={recipe} featured />
 */
import { imageUrl, imageSrcSet, placeholderColor } from '@lib/image';
import { formatTotalTime, capitalize } from '@lib/recipeHelpers';

interface RecipeData {
  _id: string;
  title: string;
  slug: { current: string };
  description?: string;
  mainImage?: any;
  prepTime?: number;
  cookTime?: number;
  servings?: number;
  difficulty?: string;
  categories?: Array<{ title: string; slug: { current: string } }>;
}

interface Props {
  recipe: RecipeData;
  /** Larger card variant for featured positions */
  featured?: boolean;
  /** Eager loading for above-fold cards */
  eager?: boolean;
}

const { recipe, featured = false, eager = false } = Astro.props;

const timeLabel = formatTotalTime(recipe.prepTime, recipe.cookTime);
const difficultyLabel = capitalize(recipe.difficulty);
const categoryLabel = recipe.categories?.[0]?.title || '';
const hasImage = !!recipe.mainImage?.asset;
const bgColor = placeholderColor(recipe.mainImage);

const imgSrc = hasImage ? imageUrl(recipe.mainImage, featured ? 800 : 600) : '';
const imgSrcSet = hasImage ? imageSrcSet(recipe.mainImage, featured ? [400, 600, 800, 1200] : [300, 600, 900]) : '';
const imgSizes = featured
  ? '(max-width: 768px) 100vw, 40vw'
  : '(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 25vw';
---

<a
  href={`/recipes/${recipe.slug.current}`}
  class="recipe-card group block"
>
  {/* Image wrapper */}
  <div class="overflow-hidden">
    <div class="transition-transform duration-500 ease-[cubic-bezier(0.2,0,0,1)] group-hover:scale-[1.03] relative">
      {hasImage ? (
        <img
          src={imgSrc}
          srcset={imgSrcSet}
          sizes={imgSizes}
          alt={recipe.mainImage?.alt || recipe.title}
          loading={eager ? 'eager' : 'lazy'}
          width={featured ? 800 : 600}
          height={featured ? 500 : 450}
          class:list={[
            "w-full object-cover block",
            featured ? "aspect-16/10" : "aspect-4/3",
          ]}
        />
      ) : (
        <div
          class:list={[
            "flex items-center justify-center",
            featured ? "aspect-16/10" : "aspect-4/3",
          ]}
          style={`background: linear-gradient(145deg, ${bgColor}, ${bgColor}CC);`}
        >
          <span class="text-black/10 text-[11px] font-semibold tracking-wider uppercase font-sans">photo</span>
        </div>
      )}
      {/* Category badge */}
      {categoryLabel && (
        <span class="absolute top-3.5 left-3.5 px-3 py-[5px] bg-white/[0.92] backdrop-blur-sm text-[10px] font-bold tracking-[1.5px] uppercase text-text-primary font-sans z-[2]">
          {categoryLabel}
        </span>
      )}
    </div>
  </div>

  {/* Text area */}
  <div class:list={[featured ? "pt-[18px]" : "pt-3.5"]}>
    <h3
      class:list={[
        "font-serif text-text-primary leading-[1.3] line-clamp-2 m-0",
        featured ? "text-[22px] font-medium" : "text-base font-semibold",
      ]}
    >
      {recipe.title}
    </h3>
    {(timeLabel || difficultyLabel) && (
      <div class="flex gap-4 mt-2 text-xs text-text-light font-sans font-medium">
        {timeLabel && <span>{timeLabel}</span>}
        {timeLabel && difficultyLabel && <span class="text-border">|</span>}
        {difficultyLabel && <span>{difficultyLabel}</span>}
      </div>
    )}
  </div>
</a>

<style>
  .recipe-card {
    transition: transform 0.35s cubic-bezier(0.2, 0, 0, 1), box-shadow 0.35s ease;
  }
  .recipe-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.08);
  }
</style>
