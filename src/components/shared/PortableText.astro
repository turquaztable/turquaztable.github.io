---
/**
 * PortableText.astro - Renders Sanity Portable Text (block content).
 * Uses @portabletext/to-html for server-side rendering.
 *
 * Handles: headings, paragraphs, lists, links, bold, italic,
 * block images with captions, and blockquotes.
 *
 * Usage:
 *   <PortableText content={recipe.tips} />
 */
import { toHTML } from '@portabletext/to-html';
import { imageUrl } from '@lib/image';

interface Props {
  content: any[];
  class?: string;
}

const { content, class: className = '' } = Astro.props;

if (!content?.length) return null;

const html = toHTML(content, {
  components: {
    types: {
      image: ({ value }: { value: any }) => {
        const src = value?.asset ? imageUrl(value, 800) : '';
        const alt = value?.alt || '';
        const caption = value?.caption || '';
        if (!src) return '';
        return `
          <figure class="portable-figure">
            <img src="${src}" alt="${alt}" loading="lazy" class="portable-img" />
            ${caption ? `<figcaption class="portable-caption">${caption}</figcaption>` : ''}
          </figure>
        `;
      },
    },
    marks: {
      link: ({ children, value }: { children: string; value: any }) => {
        const href = value?.href || '#';
        const blank = value?.blank;
        const rel = blank ? 'noopener noreferrer' : undefined;
        const target = blank ? '_blank' : undefined;
        return `<a href="${href}"${target ? ` target="${target}"` : ''}${rel ? ` rel="${rel}"` : ''} class="portable-link">${children}</a>`;
      },
    },
    block: {
      h2: ({ children }: { children: string }) =>
        `<h2 class="portable-h2">${children}</h2>`,
      h3: ({ children }: { children: string }) =>
        `<h3 class="portable-h3">${children}</h3>`,
      h4: ({ children }: { children: string }) =>
        `<h4 class="portable-h4">${children}</h4>`,
      blockquote: ({ children }: { children: string }) =>
        `<blockquote class="portable-quote">${children}</blockquote>`,
      normal: ({ children }: { children: string }) =>
        `<p class="portable-p">${children}</p>`,
    },
  },
});
---

<div class:list={["portable-text", className]} set:html={html} />

<style>
  .portable-text :global(.portable-h2) {
    font-family: var(--font-serif);
    font-size: 28px;
    font-weight: 500;
    color: var(--text);
    margin: 2rem 0 0.75rem;
    line-height: 1.25;
  }
  .portable-text :global(.portable-h3) {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 500;
    color: var(--text);
    margin: 1.75rem 0 0.5rem;
    line-height: 1.3;
  }
  .portable-text :global(.portable-h4) {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-md);
    margin: 1.5rem 0 0.5rem;
  }
  .portable-text :global(.portable-p) {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.75;
    color: var(--text-md);
    margin: 0 0 1rem;
  }
  .portable-text :global(.portable-link) {
    color: var(--green-deep);
    text-decoration: underline;
    text-decoration-color: var(--border);
    text-underline-offset: 2px;
    transition: text-decoration-color 0.2s ease;
  }
  .portable-text :global(.portable-link:hover) {
    text-decoration-color: var(--green-deep);
  }
  .portable-text :global(.portable-quote) {
    border-left: 3px solid var(--copper);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--text-md);
  }
  .portable-text :global(.portable-figure) {
    margin: 1.5rem 0;
  }
  .portable-text :global(.portable-img) {
    width: 100%;
    height: auto;
    display: block;
  }
  .portable-text :global(.portable-caption) {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--text-light);
    text-align: center;
    margin-top: 0.5rem;
  }
  .portable-text :global(ul),
  .portable-text :global(ol) {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.75;
    color: var(--text-md);
    margin: 0 0 1rem;
    padding-left: 1.5rem;
  }
  .portable-text :global(li) {
    margin-bottom: 0.25rem;
  }
  .portable-text :global(strong) {
    font-weight: 600;
    color: var(--text);
  }
  .portable-text :global(em) {
    font-style: italic;
  }
</style>
