---
/**
 * BlogCard.astro - Card for blog listing page.
 * Horizontal (16:10) image with title, date, and description.
 *
 * Usage:
 *   <BlogCard post={blogPost} />
 *   <BlogCard post={blogPost} featured />
 */
import { imageUrl, imageSrcSet, placeholderColor } from '@lib/image';

interface BlogPostData {
  _id: string;
  title: string;
  slug: { current: string };
  description?: string;
  mainImage?: any;
  publishedAt?: string;
}

interface Props {
  post: BlogPostData;
  featured?: boolean;
  eager?: boolean;
}

const { post, featured = false, eager = false } = Astro.props;

const hasImage = !!post.mainImage?.asset;
const bgColor = placeholderColor(post.mainImage);
const imgSrc = hasImage ? imageUrl(post.mainImage, featured ? 800 : 600) : '';
const imgSrcSetStr = hasImage ? imageSrcSet(post.mainImage, featured ? [400, 600, 800, 1200] : [300, 600, 900]) : '';
const imgSizes = featured
  ? '(max-width: 768px) 100vw, 55vw'
  : '(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw';

const dateLabel = post.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : '';
---

<a
  href={`/blog/${post.slug.current}`}
  class="blog-card group block"
>
  {featured ? (
    /* Featured layout: horizontal split */
    <div class="grid grid-cols-1 md:grid-cols-[1.15fr_1fr] gap-8 items-center">
      <div class="overflow-hidden">
        <div class="transition-transform duration-500 ease-[cubic-bezier(0.2,0,0,1)] group-hover:scale-[1.03]">
          {hasImage ? (
            <img
              src={imgSrc}
              srcset={imgSrcSetStr}
              sizes={imgSizes}
              alt={post.mainImage?.alt || post.title}
              loading={eager ? 'eager' : 'lazy'}
              width="800"
              height="500"
              class="w-full aspect-16/10 object-cover block"
            />
          ) : (
            <div
              class="aspect-16/10 flex items-center justify-center"
              style={`background: linear-gradient(145deg, ${bgColor}, ${bgColor}CC);`}
            >
              <span class="text-black/10 text-[11px] font-semibold tracking-wider uppercase font-sans">photo</span>
            </div>
          )}
        </div>
      </div>
      <div>
        {dateLabel && (
          <p class="font-sans text-xs text-text-light mb-2 m-0">{dateLabel}</p>
        )}
        <h3 class="font-serif text-[28px] font-normal text-text-primary leading-[1.25] m-0 max-md:text-xl">
          {post.title}
        </h3>
        {post.description && (
          <p class="font-sans text-sm text-text-md leading-[1.7] mt-3 mb-0 line-clamp-3">
            {post.description}
          </p>
        )}
        <span class="inline-block mt-4 font-sans text-xs font-bold tracking-wider uppercase text-copper">
          Read More &rarr;
        </span>
      </div>
    </div>
  ) : (
    /* Standard card layout: vertical */
    <>
      <div class="overflow-hidden">
        <div class="transition-transform duration-500 ease-[cubic-bezier(0.2,0,0,1)] group-hover:scale-[1.03]">
          {hasImage ? (
            <img
              src={imgSrc}
              srcset={imgSrcSetStr}
              sizes={imgSizes}
              alt={post.mainImage?.alt || post.title}
              loading={eager ? 'eager' : 'lazy'}
              width="800"
              height="500"
              class="w-full aspect-16/10 object-cover block"
            />
          ) : (
            <div
              class="aspect-16/10 flex items-center justify-center"
              style={`background: linear-gradient(145deg, ${bgColor}, ${bgColor}CC);`}
            >
              <span class="text-black/10 text-[11px] font-semibold tracking-wider uppercase font-sans">photo</span>
            </div>
          )}
        </div>
      </div>
      <div class="pt-3.5">
        {dateLabel && (
          <p class="font-sans text-xs text-text-light mb-2 m-0">{dateLabel}</p>
        )}
        <h3 class="font-serif text-lg font-semibold text-text-primary leading-[1.3] line-clamp-2 m-0">
          {post.title}
        </h3>
        {post.description && (
          <p class="font-sans text-xs text-text-light leading-[1.6] mt-2 mb-0 line-clamp-2">
            {post.description}
          </p>
        )}
      </div>
    </>
  )}
</a>

<style>
  .blog-card {
    transition: transform 0.35s cubic-bezier(0.2, 0, 0, 1), box-shadow 0.35s ease;
  }
  .blog-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.08);
  }
</style>
