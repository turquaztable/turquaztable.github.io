---
/**
 * FashionCard.astro - Fashion & makeup card for listing pages.
 * Portrait (3:4) image with title and postType badge.
 *
 * Usage:
 *   <FashionCard post={fashionPost} />
 */
import Badge from '@components/shared/Badge.astro';
import { imageUrl, imageSrcSet, placeholderColor } from '@lib/image';

interface FashionPostData {
  _id: string;
  title: string;
  slug: { current: string };
  postType?: string;
  description?: string;
  gallery?: any[];
  publishedAt?: string;
}

interface Props {
  post: FashionPostData;
  eager?: boolean;
}

const { post, eager = false } = Astro.props;

const postTypeLabels: Record<string, string> = {
  fashion: 'Fashion',
  makeup: 'Makeup',
  cosplay: 'Cosplay',
  hair: 'Hair',
  'style-guide': 'Style Guide',
};

const typeLabel = post.postType ? postTypeLabels[post.postType] || post.postType : '';
const firstImage = post.gallery?.[0];
const hasImage = !!firstImage?.asset;
const bgColor = placeholderColor(firstImage);
const imgSrc = hasImage ? imageUrl(firstImage, 600) : '';
const imgSrcSetStr = hasImage ? imageSrcSet(firstImage, [300, 600, 900]) : '';
---

<a
  href={`/fashion/${post.slug.current}`}
  class="fashion-card group block"
>
  {/* Image */}
  <div class="overflow-hidden relative">
    <div class="transition-transform duration-500 ease-[cubic-bezier(0.2,0,0,1)] group-hover:scale-[1.03]">
      {hasImage ? (
        <img
          src={imgSrc}
          srcset={imgSrcSetStr}
          sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
          alt={firstImage?.alt || post.title}
          loading={eager ? 'eager' : 'lazy'}
          width="600"
          height="800"
          class="w-full aspect-3/4 object-cover block"
        />
      ) : (
        <div
          class="aspect-3/4 flex items-center justify-center"
          style={`background: linear-gradient(145deg, ${bgColor}, ${bgColor}CC);`}
        >
          <span class="text-black/10 text-[11px] font-semibold tracking-wider uppercase font-sans">photo</span>
        </div>
      )}
    </div>
    {/* Post type badge */}
    {typeLabel && (
      <span class="absolute top-3.5 left-3.5 z-[2]">
        <Badge label={typeLabel} variant="overlay" />
      </span>
    )}
  </div>

  {/* Text */}
  <div class="pt-3.5">
    <h3 class="font-serif text-base font-semibold text-text-primary leading-[1.3] line-clamp-2 m-0">
      {post.title}
    </h3>
    {post.description && (
      <p class="mt-1.5 text-xs text-text-light font-sans font-medium m-0 line-clamp-2">
        {post.description}
      </p>
    )}
  </div>
</a>

<style>
  .fashion-card {
    transition: transform 0.35s cubic-bezier(0.2, 0, 0, 1), box-shadow 0.35s ease;
  }
  .fashion-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.08);
  }
</style>
